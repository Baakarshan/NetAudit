# Compose 项目名
COMPOSE_PROJECT_NAME=netaudit

# PostgreSQL 配置
POSTGRES_DB=netaudit
POSTGRES_USER=netaudit
POSTGRES_PASSWORD=netaudit

# 端口映射
BACKEND_PORT=8080
FRONTEND_PORT=5173

# 镜像（默认走 Docker Hub）
POSTGRES_IMAGE=postgres:15-alpine
BACKEND_BUILDER_IMAGE=gradle:8.10.2-jdk21-alpine
BACKEND_RUNTIME_IMAGE=eclipse-temurin:21-jre-alpine
FRONTEND_NODE_IMAGE=node:20-alpine
FRONTEND_NGINX_IMAGE=nginx:alpine
FRONTEND_NPM_REGISTRY=https://registry.npmjs.org
FRONTEND_NPM_REGISTRY_FALLBACK=https://registry.npmmirror.com
TEST_NGINX_IMAGE=nginx:alpine
TEST_FTP_IMAGE=fauria/vsftpd:latest
TEST_TELNET_ALPINE_IMAGE=alpine:3.19
TEST_DNS_PYTHON_IMAGE=python:3.12-alpine
TEST_SMTP_PYTHON_IMAGE=python:3.12-alpine
TEST_POP3_PYTHON_IMAGE=python:3.12-alpine
TEST_CLIENT_ALPINE_IMAGE=alpine:3.19
